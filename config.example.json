                "--flash-attn", "on",
                "--chat-template-kwargs", "{\"enable_thinking\":true}",
                "--temp", "0.6"
            ]
        },
        "default": {
            "description": "Small Fast Model (e.g., 9B) — Fallback",
            "args": [
                "-m", "models/default-model.gguf",
                "-c", "32768",
                "-ngl", "99",
                "--flash-attn", "on",
                "--temp", "0.7"
